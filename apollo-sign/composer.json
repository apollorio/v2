{
    "name": "apollo/sign",
    "description": "Apollo Sign — Assinatura Digital ICP-Brasil para documentos Apollo Docs",
    "type": "wordpress-plugin",
    "license": "proprietary",
    "homepage": "https://apollo.rio.br",
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.1",
        "ext-openssl": "*",
        "jeidison/signer-php": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Apollo\\Sign\\": "src/"
        }
    },
    "extra": {
        "apollo-layer": "L5",
        "depends": ["apollo-core", "apollo-docs"]
    }
}
