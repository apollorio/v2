<script>
// Avatar Upload
function uploadAvatar() {
    alert('Funcionalidade de upload de avatar seria acionada aqui');
    // Trigger file input or open upload modal
}

// Hide Post
function hidePost(btn) {
    const card = btn.closest('.feed-card');
    if (confirm('Ocultar esta postagem do seu perfil?')) {
        card.style.opacity = '0.5';
        card.style.pointerEvents = 'none';
        alert('Postagem ocultada');
    }
}

// Delete Post
function deletePost(btn) {
    const card = btn.closest('.feed-card');
    if (confirm('Excluir esta postagem permanentemente?')) {
        card.style.transform = 'scale(0.8)';
        card.style.opacity = '0';
        setTimeout(() => {
            card.remove();
        }, 300);
    }
}

// Save Changes
function saveChanges() {
    alert('Salvando alterações...');
    // Collect all edited values and send to backend
    window.location.href = 'profile.html'; // Navigate back to view mode
}

// Cancel Edit
function cancelEdit() {
    if (confirm('Descartar todas as alterações?')) {
        window.location.href = 'profile.html'; // Navigate back to view mode
    }
}

// Auto-expand input fields
document.querySelectorAll('.editable-input').forEach(input => {
    input.addEventListener('input', function() {
        this.style.width = (this.value.length + 2) + 'ch';
    });
});
</script>
