{
    "name": "apollo/apollo-{slug}",
    "description": "Apollo {Name} - {Description}",
    "type": "wordpress-plugin",
    "license": "proprietary",
    "authors": [
        {
            "name": "Apollo::Rio",
            "homepage": "https://apollo.rio.br"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "autoload": {
        "psr-4": {
            "Apollo\\{Namespace}\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
